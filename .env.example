# Redis Configuration
REDIS_HOST=192.168.1.73
REDIS_PORT=6379
REDIS_DB=0

# Encrypted Private Key (REQUIRED)
ENCRYPT_PRIVATE_KEY=your_encrypted_private_key_here

# Polymarket Proxy Wallet (REQUIRED)
PROXY_ADDRESS=0xYourProxyWalletAddress

# Blockchain Configuration
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key
CHAIN_ID=137

# Asset Configuration
ASSET=bitcoin

# Relayer Authentication (choose ONE method)

# Method 1: Relayer API Key (from Polymarket UI → Relay API Keys)
RELAYER_API_KEY=your_relayer_api_key

# Method 2: Builder API Key (derived programmatically, needs all three)
# POLY_BUILDER_API_KEY=your_builder_api_key
# POLY_BUILDER_API_SECRET=your_builder_api_secret
# POLY_BUILDER_API_PASSPHRASE=your_builder_api_passphrase

# Optional relayer settings
RELAYER_URL=https://relayer-v2.polymarket.com/
RELAYER_TX_TYPE=PROXY

# Merge Settings
# Minimum token balance to merge (in raw units, pUSD has 6 decimals)
# 10_000_000 = 10 pUSD, 50_000_000 = 50 pUSD
MIN_MERGE_AMOUNT=10000000

# Maximum transactions per batch (reduces API calls)
BATCH_SIZE=10

# Maximum API calls per hour (prevents quota exhaustion)
HOURLY_QUOTA_LIMIT=20

# Interval between merge cycles in milliseconds (default: 15 minutes)
MERGE_INTERVAL_MS=900000

# Delay between batches in milliseconds (default: 5 seconds)
REQUEST_DELAY_MS=5000

# Node Environment
NODE_ENV=development
